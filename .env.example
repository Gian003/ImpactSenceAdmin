APP_NAME=ImpactSense
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (MySQL 8.0) ───────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=impactsense
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Broadcasting (Pusher) ─────────────────────────────────────────────────────
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# FIREBASE_PROJECT_ID  — your Firebase project ID (e.g. impactsense-xyz)
# FIREBASE_SERVICE_ACCOUNT_JSON — absolute path to service-account JSON file
#   OR the raw JSON string itself (for environments without filesystem access)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Google Maps (TOC location tracking, incident report map) ─────────────────
# Needs "Maps JavaScript API" enabled + billing active in Google Cloud Console.
# If the map fails to load, check this key's HTTP referrer restrictions match
# the domain/IP you're accessing the app from.
GOOGLE_MAPS_API_KEY=

# ── Mail (Resend) ─────────────────────────────────────────────────────────────
# Get a free API key at https://resend.com/api-keys (no password/app-password needed).
# Until you verify your own sending domain on Resend, MAIL_FROM_ADDRESS must stay
# "onboarding@resend.dev" and emails can only be delivered to the address you signed
# up with. Verify a domain at https://resend.com/domains to send to anyone.
MAIL_MAILER=resend
RESEND_API_KEY=your-resend-api-key
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
